# Core bot settings (replaces config.json)
PREFIX=.
OWNER_ID=100095180674234
OWNER_NAME=Keith
BOT_NAME=Fbot-V1.8
AUTO_RESTART=false
AUTO_GREET=false
PORT=3000

# ws3-fca api.setOptions
FORCE_LOGIN=true
LISTEN_EVENTS=true
LOG_LEVEL=error
SELF_LISTEN=true
UPDATE_PRESENCE=true
AUTO_MARK_DELIVERY=true
AUTO_MARK_READ=true
ONLINE=true

# --- Facebook login ---------------------------------------------------------
# Preferred: gzip+base64 encoded appState cookies, as ONE line.
# Generate this with: node tools/encode-appstate.js path/to/appState.json
APPSTATE=

# Fallback, only used if APPSTATE above is empty/invalid:
FB_EMAIL=
FB_PASSWORD=
